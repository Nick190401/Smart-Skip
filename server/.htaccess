# Smart Skip v2 — merged into site/public/.htaccess for deployment.
# This file is kept as the source-of-truth reference for the server config.
# Deploy site/public/.htaccess to public_html/ — it covers both SPA routing
# and PHP security in one place.

Options -Indexes

# ── PHP upload limits (shared hosting — Hostinger) ────────────────────────────
# Raises the default 2 MB cap to 6 MB so 5 MB attachments fit with multipart overhead.
<IfModule mod_php.c>
    php_value upload_max_filesize 6M
    php_value post_max_size       7M
    php_value max_file_uploads    5
</IfModule>
# For PHP-FPM (Hostinger default since ~2023) these are set via .user.ini instead:

# ── PHP security ──────────────────────────────────────────────────────────────
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

<Files ".user.ini">
    Order Allow,Deny
    Deny from all
</Files>

<FilesMatch "^(?!api\.php|auth\.php|privacy\.php).*\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── SPA routing ───────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/api\.php
    RewriteCond %{REQUEST_URI} !^/auth\.php
    RewriteCond %{REQUEST_URI} !^/privacy\.php
    RewriteRule ^ /index.html [L]
</IfModule>
